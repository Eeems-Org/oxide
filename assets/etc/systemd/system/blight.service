[Unit]
Description=Oxide display server
After=home.mount
StartLimitInterval=30
StartLimitBurst=5
OnFailure=launcherctl-failure.service
Before=remarkable-reboot.service remarkable-shutdown.service

[Service]
Type=dbus
BusName=codes.eeems.blight1
ExecStart=/home/root/.vellum/bin/blight --break-lock
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
