{
    "displayName": "Settings",
    "description": "Configure device settings",
    "bin": "/home/root/.vellum/share/oxide/libexec/codes.eeems.settings",
    "type": "backgroundable",
    "permissions": ["wifi", "power", "system", "screen", "notification", "apps", "frontlight"],
    "flags": ["nopreload", "noannounce", "topbar", "forking"]
}
