#!/bin/bash
set -e
device="$(cat /sys/devices/soc0/machine)"
case "$(basename "${EXECUTABLE:?EXECUTABLE missing}")" in
puzzles)
  export OXIDE_PRELOAD_FORCE_INVERT_TOUCH_X=1
  export OXIDE_PRELOAD_FORCE_32BIT_FSCREEN=1
  ;;
tilem | yaft)
  export OXIDE_PRELOAD_FORCE_RM1=1
  ;;
chessmarkable)
  if [[ "$device" != "reMarkable 2.0" ]]; then
    export OXIDE_PRELOAD_FORCE_RM1=1
  fi
  export OXIDE_PRELOAD_FORCE_32BIT_FSCREEN=1
  ;;
doommarkable)
  if [[ "$device" != "reMarkable 2.0" ]]; then
    export OXIDE_PRELOAD_FORCE_RM1=1
  fi
  export OXIDE_PRELOAD_FORCE_32BIT_FSCREEN=1
  ;;
koreader.sh)
  if [[ "$device" == "reMarkable Chiappa" ]] || [[ "$device" == "reMarkable Ferrari" ]]; then
    export OXIDE_PRELOAD_FORCE_RM1=1
  elif [[ "$device" == "reMarkable Tatsu" ]]; then
    export OXIDE_PRELOAD_FORCE_RM1_INPUT=1
  fi
  export LD_LIBRARY_PATH="$(dirname "$EXECUTABLE")/libs"
  export PATH="/home/root/.vellum/bin:/usr/bin"
  ;;
esac
eval "set -- $ARGUMENTS"
exec /home/root/.vellum/bin/blight-client "$EXECUTABLE" "$@"
