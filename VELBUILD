subpackages='
fbinfo
inject_evdev
liboxide
liboxide-dev:liboxide_dev
cpptrace
cpptrace-dev:cpptrace_dev
oxide-display:oxide_display
oxide-extra:oxide_extra
oxide-utils:oxide_utils
oxide-tests:oxide_tests
lockscreen_hook
'
pkgname=oxide
pkgver="~VERSION~"
pkgrel=0
_cpptracever=0.8.3
upstream_author="Eeems-org"
maintainer="Eeems <eeems@eeems.email>"
url=https://oxide.eeems.codes
license=MIT
source='
oxide.tar.gz
'
pkgdesc="Launcher application"
category="apps"
options="!check !fhs !strip !tracedeps"

_toolchain=5.7.119
image() {
    case "$CARCH" in
    aarch64) echo "eeems/remarkable-toolchain:$_toolchain-rmpp" ;;
    armv7) echo "eeems/remarkable-toolchain:$_toolchain-rm1" ;;
    *)
        echo "Invalid CARCH: $CARCH"
        exit 1
        ;;
    esac
}

build() {
    _toolchain=5.7.119 # Is not currently passed into build()
    set -e
    cd "$srcdir"
    case "$CARCH" in
    aarch64)
        . /opt/codex/ferrari/"$_toolchain"/environment-setup-cortexa53-crypto-remarkable-linux
        ;;
    armv7)
        . /opt/codex/rm1/"$_toolchain"/environment-setup-cortexa9hf-neon-remarkable-linux-gnueabi
        ;;
    *)
        echo "Invalid CARCH: $CARCH"
        exit 1
        ;;
    esac
    make release
}

package() {
    cd "$srcdir"/release
    # System service
    install -Dm644 -t "$pkgdir"/home/root/.vellum/share/oxide/dbus-1/system.d \
        etc/dbus-1/system.d/codes.eeems.oxide.conf
    install -Dm644 -t "$pkgdir"/home/root/.vellum/share/oxide/systemd/system \
        etc/systemd/system/tarnish.service
    install -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/tarnish
    # Task manager
    install -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/erode
    install -Dm644 -t "$pkgdir"/home/root/.local/share/icons/oxide/48x48/apps \
        home/root/.local/share/icons/oxide/48x48/apps/erode.png
    install -Dm644 -t "$pkgdir"/home/root/.local/share/applications \
        home/root/.local/share/applications/codes.eeems.erode.oxide
    # Launcher
    install -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/oxide
    install -Dm644 -t "$pkgdir"/home/root/.config/ \
        home/root/.config/oxide.conf
    install -Dm644 -t "$pkgdir"/home/root/.local/share/applications \
        home/root/.local/share/applications/codes.eeems.oxide.oxide
    install -Dm644 -t "$pkgdir"/home/root/.local/share/icons/oxide/702x702/splash \
        home/root/.local/share/icons/oxide/702x702/splash/oxide.png
    # Lockscreen
    install -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/decay
    install -Dm644 -t "$pkgdir"/home/root/.local/share/applications \
        home/root/.local/share/applications/codes.eeems.decay.oxide
    # Task switcher
    install -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/corrupt
    install -Dm644 -t "$pkgdir"/home/root/.local/share/applications \
        home/root/.local/share/applications/codes.eeems.corrupt.oxide
    # Keyd configuration
    install -Dm644 -t "$pkgdir"/home/root/.config/keyd \
        home/root/.config/keyd/oxide.conf
}

postinstall() {
    mount-rw
    postosupgrade
    mount-restore
}

postupgrade() {
    postinstall
}

postosupgrade() {
    mkdir -p /etc/dbus-1/system.d
    cp -a /home/root/.vellum/share/oxide/dbus-1/system.d/codes.eeems.oxide.conf \
        etc/dbus-1/system.d/
    cp -a /home/root/.vellum/share/oxide/systemd/system/tarnish.service \
        etc/systemd/system/
    systemctl daemon-reload
}

predeinstall() {
    rm -f /etc/dbus-1/system.d/codes.eeems.oxide.conf
    rm -f /etc/systemd/system/tarnish.service
    systemctl daemon-reload
}

oxide_display() {
    pkgdesc="Oxide display server"
    category="framework"
    depends="
    liboxide=$pkgver
    cpptrace=$_cpptracever
    "

    package() {
        cd "$srcdir"/release
        # Display server
        install -Dm644 -t "$subpkgdir"/home/root/.vellum/share/oxide/dbus-1/system.d \
            etc/dbus-1/system.d/codes.eeems.blight.conf
        install -Dm644 -t "$subpkgdir"/home/root/.vellum/share/oxide/systemd/system \
            etc/systemd/system/blight.service
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/blight
        # Client
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/lib \
            home/root/.vellum/lib/libblight_client.so*
        # QPA
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/usr/lib/plugins/platforms \
            home/root/.vellum/usr/lib/plugins/platforms/liboxide.so*
    }

    postinstall() {
        mount-rw
        postosupgrade
        mount-restore
    }

    postupgrade() {
        postinstall
    }

    postosupgrade() {
        mkdir -p /etc/dbus-1/system.d
        cp -a /home/root/.vellum/share/oxide/dbus-1/system.d/codes.eeems.blight.conf \
            etc/dbus-1/system.d/
        cp -a /home/root/.vellum/share/oxide/systemd/system/blight.service \
            etc/systemd/system/
        systemctl daemon-reload
    }

    predeinstall() {
        rm -f /etc/dbus-1/system.d/codes.eeems.blight.conf
        rm -f /etc/systemd/system/blight.service
        systemctl daemon-reload
    }
}

oxide_extra() {
    pkgdesc="Extra applications for oxide"
    category="apps"
    depends="
    oxide=$pkgver
    oxide-utils=$pkgver
    liboxide=$pkgver
    cpptrace=$_cpptracever
    "

    package() {
        cd "$srcdir"/release
        # Screenshot viewer
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/anxiety
        install -Dm644 -t "$subpkgdir"/home/root/.local/share/applications \
            home/root/.local/share/applications/codes.eeems.anxiety.oxide
        install -Dm644 -t "$subpkgdir"/home/root/.local/share/icons/oxide/48x48/apps \
            home/root/.local/share/icons/oxide/48x48/apps/image.png
    }
}

oxide_utils() {
    pkgdesc="Command line tools for Oxide"
    category="utilities"
    depends="
    oxide=$pkgver
    liboxide=$pkgver
    cpptrace=$_cpptracever
    "

    package() {
        cd "$srcdir"/release
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/desktop-file-validate
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/gio
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/notify-send
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/rot
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/update-desktop-database
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/xclip
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/xdg-desktop-icon
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/xdg-desktop-menu
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/xdg-open
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/xdg-settings
    }
}

inject_evdev() {
    pkgdesc="Inject input events"
    category="utilities"
    depends="
    liboxide=$pkgver
    cpptrace=$_cpptracever
    "

    package() {
        cd "$srcdir"/release
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/inject_evdev
    }
}

fbinfo() {
    pkgdesc="Print out framebuffer info"
    category="utilities"

    package() {
        cd "$srcdir"/release
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/bin \
            home/root/.vellum/bin/fbinfo
    }
}

liboxide() {
    pkgdesc="Shared library for oxide applications"
    category="framework"

    package() {
        cd "$srcdir"/release
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/lib \
            home/root/.vellum/lib/liboxide.so*
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/lib \
            home/root/.vellum/lib/libblight.so*
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/lib \
            home/root/.vellum/lib/libblight_protocol.so*
    }
}

liboxide_dev() {
    pkgdesc="Shared library for oxide applications"
    category="framework"
    depends="liboxide=$pkgver"

    package() {
        cd "$srcdir"/release
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/lib/pkgconfig \
            home/root/.vellum/lib/pkgconfig/oxide.pc
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/include \
            home/root/.vellum/include/epframebuffer.h
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/include \
            home/root/.vellum/include/liboxide.h
        cp -ar home/root/.vellum/include/liboxide/ \
            "$subpkgdir"/home/root/.vellum/include/
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/include \
            home/root/.vellum/include/libblight.h
        cp -ar home/root/.vellum/include/libblight/ \
            "$subpkgdir"/home/root/.vellum/include/
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/include \
            home/root/.vellum/include/libblight_protocol.h
        cp -ar home/root/.vellum/include/libblight_protocol/ \
            "$subpkgdir"/home/root/.vellum/include/
    }
}

cpptrace() {
    pkgdesc="Simple, portable, and self-contained stacktrace library for C++11 and newer"
    category="framework"
    url=https://github.com/jeremy-rifkin/cpptrace
    pkgver="$_cpptracever"

    package() {
        cd "$srcdir"/release
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/lib \
            home/root/.vellum/lib/libcpptrace.so
    }
}
cpptrace_dev() {
    pkgdesc="Simple, portable, and self-contained stacktrace library for C++11 and newer"
    category="framework"
    url=https://github.com/jeremy-rifkin/cpptrace
    pkgver="$_cpptracever"

    package() {
        cd "$srcdir"/release
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/lib \
            home/root/.vellum/lib/libcpptrace.so
    }
}

oxide_tests() {
    pkgdesc="Automated tests for oxide"
    category="framework"
    depends="
    oxide-display=$pkgver
    "

    package() {
        cd "$srcdir"/release
        install -Dm755 -t "$subpkgdir"/home/root/.local/share/tests \
            home/root/.local/share/tests/libblight
        install -Dm755 -t "$subpkgdir"/home/root/.local/share/tests \
            home/root/.local/share/tests/libblight_protocol
        install -Dm755 -t "$subpkgdir"/home/root/.local/share/tests \
            home/root/.local/share/tests/liboxide
    }
}

lockscreen_hook() {
    pkgdesc="Run scripts after unlock"
    category="framework"
    depends='
    remarkable-os>=3.27.1.0
    '
    package() {
        cd "$srcdir"/release
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/usr/lib \
            usr/lib/liblockscreen_hook.so*
        install -Dm755 -t "$subpkgdir"/home/root/.vellum/share/lockscreen_hook/ \
            etc/systemd/system/xochitl.service.d/lockscreen_hook.conf
    }

    postinstall() {
        mount-rw
        postosupgrade
        mount-restore
    }

    postupgrade() {
        postinstall
    }

    postosupgrade() {
        mkdir -p /etc/systemd/system/xochitl.service.d/
        cp -a /home/root/.vellum/share/lockscreen_hook/lockscreen_hook.conf \
            etc/systemd/system/xochitl.service.d/
        systemctl daemon-reload
    }

    predeinstall() {
        rm -f /etc/systemd/system/xochitl.service.d/lockscreen_hook.conf
        systemctl daemon-reload
    }
}
