launcherctl
launcherctl-oxide:launcherctl_oxide
'
pkgname=oxide
pkgver="~VERSION~"
pkgrel=~TIMESTAMP~
upstream_author="Eeems-Org"
maintainer="Eeems <eeems@eeems.email>"
url=https://oxide.eeems.codes
license=MIT
source='
oxide.tar.gz
'
readmeurl="https://raw.githubusercontent.com/$upstream_author/oxide/refs/heads/master/README.md"
pkgdesc="Launcher application"
category="apps"
arch="armv7 aarch64"
depends="
oxide-display=$pkgver-r$pkgrel
liboxide=$pkgver-r$pkgrel
"

_toolchain=5.7.119
image() {
    case "$CARCH" in
    aarch64) echo "eeems/remarkable-toolchain:$_toolchain-rmpp" ;;
    armv7) echo "eeems/remarkable-toolchain:$_toolchain-rm1" ;;
    *)
        echo "Invalid CARCH: $CARCH"
        exit 1
        ;;
    esac
}

build() {
    _toolchain=5.7.119 # Is not currently passed into build()
    set -e
    cd "$srcdir"
    case "$CARCH" in
    aarch64)
        . /opt/codex/ferrari/"$_toolchain"/environment-setup-cortexa53-crypto-remarkable-linux
        ;;
    armv7)
        . /opt/codex/rm1/"$_toolchain"/environment-setup-cortexa9hf-neon-remarkable-linux-gnueabi
        ;;
    *)
        echo "Invalid CARCH: $CARCH"
        exit 1
        ;;
    esac
    make FEATURES='sentry debug' release
}

package() {
    cd "$srcdir"/release
    # System service
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.vellum/share/oxide/dbus-1/system.d \
        etc/dbus-1/system.d/codes.eeems.oxide.conf
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.vellum/share/oxide/systemd/system \
        etc/systemd/system/tarnish.service
    install -o root -g root -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/tarnish
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.local/share/applications \
        home/root/.local/share/applications/xochitl.oxide
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.local/share/icons/oxide/48x48/apps \
        home/root/.local/share/icons/oxide/48x48/apps/xochitl.png
    install -o root -g root -Dm755 -t "$pkgdir"/home/root/.vellum/share/oxide/libexec \
        home/root/.vellum/share/oxide/libexec/runner
    # Task manager
    install -o root -g root -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/erode
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.local/share/icons/oxide/48x48/apps \
        home/root/.local/share/icons/oxide/48x48/apps/erode.png
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.local/share/applications \
        home/root/.local/share/applications/codes.eeems.erode.oxide
    # Launcher
    install -o root -g root -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/oxide
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.config/ \
        home/root/.config/oxide.conf
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.local/share/applications \
        home/root/.local/share/applications/codes.eeems.oxide.oxide
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.local/share/icons/oxide/702x702/splash \
        home/root/.local/share/icons/oxide/702x702/splash/oxide.png
    # Lockscreen
    install -o root -g root -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/decay
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.local/share/applications \
        home/root/.local/share/applications/codes.eeems.decay.oxide
    # Task switcher
    install -o root -g root -Dm755 -t "$pkgdir"/home/root/.vellum/bin \
        home/root/.vellum/bin/corrupt
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.local/share/applications \
        home/root/.local/share/applications/codes.eeems.corrupt.oxide
    # Keyd configuration
    install -o root -g root -Dm644 -t "$pkgdir"/home/root/.config/keyd \
        home/root/.config/keyd/oxide.conf
    install -Dm644 "$srcdir/LICENSE.md" \
        "$pkgdir/home/root/.vellum/licenses/$pkgname/LICENSE"
    echo "https://github.com/Eeems/oxide" > \
        "$pkgdir/home/root/.vellum/licenses/$pkgname/SOURCES"
}

postinstall() {
    set -e
    /home/root/.vellum/bin/mount-rw
    postosupgrade
    /home/root/.vellum/bin/mount-restore
}

postupgrade() {
    set -e
    postinstall
    if [ -f /home/root/.vellum/bin/update-desktop-database ]; then
        /home/root/.vellum/bin/update-desktop-database
    fi
    if systemctl is-active --quiet tarnish; then
        echo "Oxide is currently running and will need to be restarted"
    fi
}

postosupgrade() {
    set -e
    mkdir -p \
        /etc/dbus-1/system.d \
        /etc/systemd/system
    rm -f \
        /var/volatile/etc/systemd/system/tarnish.service \
        /var/volatile/etc/systemd/system/tarnish.service
    cp -a /home/root/.vellum/share/oxide/dbus-1/system.d/codes.eeems.oxide.conf \
        /etc/dbus-1/system.d/
    cp -a /home/root/.vellum/share/oxide/systemd/system/tarnish.service \
        /etc/systemd/system/
    systemctl daemon-reload
    systemctl reload dbus
}

predeinstall() {
    set -e
    if [ "$(systemctl --quiet list-unit-files tarnish.service | /bin/grep -c tarnish.service 2>/dev/null)" -eq 1 ]; then
        if systemctl --quiet is-active tarnish.service 2>/dev/null; then
            systemctl stop tarnish.service
        fi
        if systemctl --quiet is-enabled tarnish.service 2>/dev/null; then
            systemctl disable tarnish.service
        fi
    fi
    rm -f \
        /etc/dbus-1/system.d/codes.eeems.oxide.conf \
        /etc/systemd/system/tarnish.service
    systemctl daemon-reload
}

postdeinstall() {
    set -e
    rm -f \
        /var/volatile/etc/systemd/system/tarnish.service \
        /var/volatile/etc/systemd/system/tarnish.service
}

