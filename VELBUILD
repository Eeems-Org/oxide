            home/root/.local/share/lockscreen_hook.d/unlock
        install -o root -g root -Dm755 -t "$subpkgdir"/home/root/.local/share/lockscreen_hook.d \
            home/root/.local/share/lockscreen_hook.d/success
        install -o root -g root -Dm644 -t "$subpkgdir"/home/root/.vellum/share/launcherctl/systemd \
            etc/systemd/system/launcherctl-failure.service
        install -Dm644 "$srcdir/LICENSE.md" \
            "$subpkgdir/home/root/.vellum/licenses/launcherctl/LICENSE"
        echo "https://github.com/Eeems/oxide" > \
            "$subpkgdir/home/root/.vellum/licenses/launcherctl/SOURCES"
    }
    postinstall() {
        set -e
        /home/root/.vellum/bin/mount-rw
        postosupgrade
        /home/root/.vellum/bin/mount-restore
    }
    postupgrade() {
        set -e
        postinstall
    }
    postosupgrade() {
        set -e
        rm -f /var/volatile/etc/systemd/system/launcherctl-failure.service
        cp -a /home/root/.vellum/share/launcherctl/systemd/launcherctl-failure.service \
            /etc/systemd/system/
        systemctl daemon-reload
        /home/root/.vellum/bin/launcherctl status
    }
    predeinstall() {
        set -e
        if [[ "$(/home/root/.vellum/bin/launcherctl active-launcher)" != "none" ]]; then
            /home/root/.vellum/bin/launcherctl stop-launcher
            /home/root/.vellum/share/launcherctl/none start
        fi
        rm -f /etc/systemd/system/launcherctl-failure.service
        systemctl daemon-reload
        if [ "$VELLUM_PURGE" = "1" ]; then
            rm -f /home/root/.vellum/share/launcherctl/current
        fi
    }
    postdeinstall() {
        set -e
        systemctl enable --now xochitl
    }
}

launcherctl_oxide() {
    pkgdesc="Launcherctl configuration for oxide"
    category="utilities"
    depends="
    oxide=$pkgver-r$pkgrel
    oxide-utils=$pkgver-r$pkgrel
    launcherctl
    "
    package() {
        cd "$srcdir"/release
        install -o root -g root -Dm755 -t "$subpkgdir"/home/root/.vellum/share/launcherctl \
            home/root/.vellum/share/launcherctl/oxide
        install -Dm644 "$srcdir/LICENSE.md" \
            "$subpkgdir/home/root/.vellum/licenses/launcherctl-oxide/LICENSE"
        echo "https://github.com/Eeems/oxide" > \
            "$subpkgdir/home/root/.vellum/licenses/launcherctl-oxide/SOURCES"
    }

    predeinstall() {
        set -e
        if [[ "$(/home/root/.vellum/bin/launcherctl current-launcher)" == "oxide" ]]; then
            /home/root/.vellum/bin/launcherctl switch-launcher none
        fi
    }
}
